{
  "name": "night-drift",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "assets": "node scripts/copy-assets.mjs",
    "dev": "vite",
    "build": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "start": "node build/server/index.js",
    "server": "tsx --env-file-if-exists=.env src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.1",
    "@colyseus/schema": "^2.0.32",
    "@colyseus/tools": "^0.15.49",
    "colyseus": "^0.15.17",
    "colyseus.js": "^0.15.20",
    "express": "^4.22.2",
    "three": "^0.166.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/three": "^0.166.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
